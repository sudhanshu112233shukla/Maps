{
  "name": "ai-map-system",
  "version": "1.0.0",
  "description": "On-device AI Map — Offline routing for Europe, Americas, India, Japan, South Korea, Canada, Russia",
  "main": "index.html",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "cap:add:android": "npx cap add android",
    "cap:add:ios": "npx cap add ios",
    "cap:sync": "npx cap sync",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "cap:run:android": "npx cap run android",
    "mobile:build": "vite build && npx cap sync",
    "graph:build": "python tools/osm_pipeline/build_from_manifest.py",
    "graph:build:india": "python tools/osm_pipeline/build_from_manifest.py --region-id india",
    "graph:build:usa": "python tools/osm_pipeline/build_from_manifest.py --region-id usa",
    "graph:build:skorea": "python tools/osm_pipeline/build_from_manifest.py --region-id skorea",
    "graph:build:europe": "python tools/osm_pipeline/build_from_manifest.py --region-id europe",
    "graph:validate": "python tools/osm_pipeline/validate_graph_bundle.py",
    "graph:validate:india": "python tools/osm_pipeline/validate_graph_bundle.py --region-id india",
    "graph:validate:usa": "python tools/osm_pipeline/validate_graph_bundle.py --region-id usa",
    "graph:validate:skorea": "python tools/osm_pipeline/validate_graph_bundle.py --region-id skorea",
    "graph:validate:europe": "python tools/osm_pipeline/validate_graph_bundle.py --region-id europe",
    "rust:search:android": "powershell -ExecutionPolicy Bypass -File native/rust-search/scripts/build_android.ps1"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/app": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/filesystem": "^6.0.0",
    "@capacitor/geolocation": "^6.0.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/ios": "^6.2.1",
    "@capacitor/preferences": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "maplibre-gl": "^4.3.0",
    "pmtiles": "^3.2.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "vite": "^5.4.0"
  }
}
