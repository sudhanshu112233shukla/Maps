{
  "name": "ai-map-system",
  "version": "1.0.0",
  "type": "module",
  "description": "On-device AI Map — Offline routing for Europe, Americas, India, Japan, South Korea, Canada, Russia",
  "main": "index.html",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "cap:add:android": "npx cap add android",
    "cap:add:ios": "npx cap add ios",
    "cap:sync": "npx cap sync",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "cap:run:android": "npx cap run android",
    "mobile:build": "vite build && npx cap sync",
    "graph:build": "python tools/osm_pipeline/build_from_manifest.py",
    "graph:build:india": "python tools/osm_pipeline/build_from_manifest.py --region-id india",
    "graph:build:usa": "python tools/osm_pipeline/build_from_manifest.py --region-id usa",
    "graph:build:skorea": "python tools/osm_pipeline/build_from_manifest.py --region-id skorea",
    "graph:build:europe": "python tools/osm_pipeline/build_from_manifest.py --region-id europe",
    "graph:build:uk": "python tools/osm_pipeline/build_from_manifest.py --region-id uk",
    "graph:build:russia": "python tools/osm_pipeline/build_from_manifest.py --region-id russia",
    "graph:build:australia": "python tools/osm_pipeline/build_from_manifest.py --region-id australia",
    "graph:validate": "python tools/osm_pipeline/validate_graph_bundle.py",
    "graph:validate:india": "python tools/osm_pipeline/validate_graph_bundle.py --region-id india",
    "graph:validate:usa": "python tools/osm_pipeline/validate_graph_bundle.py --region-id usa",
    "graph:validate:skorea": "python tools/osm_pipeline/validate_graph_bundle.py --region-id skorea",
    "graph:validate:europe": "python tools/osm_pipeline/validate_graph_bundle.py --region-id europe",
    "graph:validate:uk": "python tools/osm_pipeline/validate_graph_bundle.py --region-id uk",
    "graph:validate:russia": "python tools/osm_pipeline/validate_graph_bundle.py --region-id russia",
    "graph:validate:australia": "python tools/osm_pipeline/validate_graph_bundle.py --region-id australia",
    "selfcheck:melange-contract": "node tools/selfcheck/melange_contract_selfcheck.mjs",
    "selfcheck:delta": "node tools/selfcheck/delta_manifest_selfcheck.mjs",
    "selfcheck:graph-pipeline": "node tools/selfcheck/graph_pipeline_selfcheck.mjs",
    "selfcheck:compose-shell": "node tools/selfcheck/compose_shell_selfcheck.mjs",
    "selfcheck:packs": "node tools/selfcheck/pack_manifest_selfcheck.mjs",
    "selfcheck:queue": "node tools/selfcheck/download_queue_selfcheck.mjs",
    "selfcheck:routing": "node tools/selfcheck/routing_selfcheck.mjs",
    "selfcheck:rust-native": "node tools/selfcheck/rust_native_activation_selfcheck.mjs",
    "selfcheck:search": "node tools/selfcheck/search_selfcheck.mjs",
    "selfcheck:storage": "node tools/selfcheck/storage_budget_selfcheck.mjs",
    "rust:search:android": "powershell -ExecutionPolicy Bypass -File native/rust-search/scripts/build_android.ps1"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/app": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/filesystem": "^6.0.0",
    "@capacitor/geolocation": "^6.0.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/ios": "^6.2.1",
    "@capacitor/preferences": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "maplibre-gl": "^4.3.0",
    "pmtiles": "^3.2.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "vite": "^5.4.0"
  }
}
