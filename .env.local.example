# Local environment overrides. Copy this file to `.env.local` and fill in values.
# `.env.local` is gitignored. Never commit real secrets.

# Zetic Personal Access Token — obtain from https://mlange.zetic.ai
# Used at build time only; the Android Gradle build injects this into BuildConfig
# and the runtime moves it into the Android Keystore on first launch.
ZETIC_PAT=

# Optional: override the LLM model for local experimentation (must be on
# Zetic's supported list — see src/ai/models.json).
# ZETIC_LLM_MODEL=google/gemma-3-4b-it

# Optional: override the speech model.
# ZETIC_SPEECH_MODEL=ZETIC-ai/whisper-base-decoder
